{
  "name": "stock-machine",
  "version": "1.0.0",
  "description": "Stock Machine is a stock management system that helps you manage your inventory with ease.",
  "author": {
    "name": "Lumexio",
    "email": "fsmsoftdev@gmail.com"
  },
  "scripts": {
    "lint": "echo \"No linting configured\"",
    "make-win": "electron-forge make --platform=win32",
    "make-linux": "electron-forge make --platform=linux",
    "make-mac": "electron-forge make --platform=darwin",
    "package-win": "electron-forge package --platform=win32",
    "package-linux": "electron-forge package --platform=linux",
    "package-mac": "electron-forge package --platform=darwin",
    "publish-win": "electron-forge publish --platform=win32",
    "publish-linux": "electron-forge publish --platform=linux",
    "publish-mac": "electron-forge publish --platform=darwin",
    "make": "electron-forge make",
    "package": "electron-forge package",
    "publish": "electron-forge publish",
    "start": "electron-forge start"
  },
  "main": ".vite/build/main.js",
  "publish": {
    "provider": "github",
    "releaseType": "release"
  },
  "repository": "https://github.com/Lumexio/ps-electron.git",
  "config": {
    "forge": "./forge.config.js"
  },
  "build": {
    "appId": "com.lumexio.stockmachine",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@electron-forge/maker-deb": "^7.7.0",
    "@mdi/font": "^7.4.47",
    "electron-log": "^5.3.2",
    "electron-squirrel-startup": "^1.0.1",
    "electron-updater": "^6.3.9",
    "idb": "^8.0.0",
    "minify-css-string": "^1.0.0",
    "pinia": "^2.1.4",
    "pinia-plugin-persistedstate": "^4.0.1",
    "update-electron-app": "^3.1.1",
    "vite-plugin-vuetify": "^2.0.4",
    "vue": "^3.4.38",
    "vue-query": "^1.26.0",
    "vue-router": "^4.0.13",
    "vue-toast-notification": "^3.1.2",
    "vuetify": "^3.7.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@electron-forge/plugin-vite": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@vitejs/plugin-vue": "^5.1.3",
    "electron": "32.0.1",
    "vite": "^5.4.2",
    "vue-cli-plugin-pinia": "~0.2.4"
  },
  "keywords": [
    "stock",
    "machine",
    "stockmachine",
    "stock-machine",
    "inventory",
    "management",
    "system",
    "ims",
    "stock management system",
    "stock management",
    "inventory management",
    "inventory management system"
  ],
  "license": "MIT",
  "productName": "STOCKMACHINE"
}